{
  "name": "web4testing",
  "version": "2.0.0",
  "description": "Versión NodeJS del servidor de pruebas para cursos de FrontEnd y con un sitio web de ejemplo donde aplicar casos de prueba WebDriver.",
  "main": "./bin/www",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "start": "node ./bin/www",
    "restart": "nodemon -w **/*.* -e js,pug ./bin/www",
    "lint": "eslint",
    "test": "jest --collectCoverage",
    "test:snapshot": "jest --updateSnapshot",
    "sonar": "sonar-scanner.bat -D\"sonar.projectKey=Web4Testing\" -D\"sonar.host.url=http://localhost:9000\" -D\"sonar.javascript.lcov.reportPaths=./coverage/lcov.info\" -D\"sonar.login=sqp_7a8f299abaf66e9c56fdb8796298fd5b697ccb03\""
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "~1.4.7",
    "debug": "~4.4.3",
    "express": "~5.2.1",
    "express-openapi-validator": "^5.6.2",
    "http-errors": "~2.0.1",
    "jsonwebtoken": "^9.0.3",
    "markdown-it": "^14.1.1",
    "morgan": "~1.10.1",
    "multer": "^2.1.1",
    "pug": "^3.0.4",
    "rotating-file-stream": "^3.2.9",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.15.35",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@html-eslint/eslint-plugin": "^0.59.0",
    "@html-eslint/parser": "^0.59.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.1",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "roots": [
      "./routes/",
      "./spec/",
      "public/javascripts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "branches": 80,
        "functions": 80,
        "statements": 80
      }
    }
  }
}
